  "key": "PROJ-123",
  "fields": {
    "summary": "Add a hello world endpoint to the Express app",
    "description": {
      "type": "doc",
      "version": 1,
      "content": [
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "We need a simple health-check / hello-world endpoint on the Express application so that infrastructure tooling and new developers can quickly verify the service is running."
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "The endpoint should live at GET /hello and return a JSON response. It must be covered by a unit test."
            }
          ]
        }
      ]
    },
    "acceptanceCriteria": "1. GET /hello returns HTTP 200\n2. Response body is JSON: { \"message\": \"Hello, world!\", \"status\": \"ok\" }\n3. A unit test exists that asserts both the status code and the response body\n4. The existing test suite continues to pass",
